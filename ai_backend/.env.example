# Required: your Google API key for Gemini embeddings and answer generation
GOOGLE_API_KEY=your-api-key-here

# Optional: path to the existing backend's SQLite database
# Default: ../backend/emails.db (relative to this directory)
DATABASE_PATH=../backend/emails.db

# Optional: directory to store FAISS/BM25 indexes
# Default: ./vector_store (relative to this directory)
# VECTOR_STORE_DIR=./vector_store

# Optional: Gemini model for answer generation
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Gemini model for embeddings
# EMBEDDING_MODEL=models/gemini-embedding-001

# Optional: index metric (cosine or l2)
# INDEX_METRIC=cosine
